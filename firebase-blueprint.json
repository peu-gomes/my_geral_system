{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Represents a development project containing metadata, status, tags, tasks, links, and AI roadmaps.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the project." },
        "title": { "type": "string", "description": "The title or name of the project." },
        "description": { "type": "string", "description": "A brief description of the project." },
        "status": {
          "type": "string",
          "enum": ["planning", "in_progress", "completed", "archived"],
          "description": "The current development phase of the project."
        },
        "source": {
          "type": "string",
          "enum": ["ai_studio", "external"],
          "description": "Where the project was initiated."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "A list of relevant technology tags."
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "completed": { "type": "boolean" }
            },
            "required": ["id", "title", "completed"]
          },
          "description": "The list of tasks or milestones for this project."
        },
        "links": {
          "type": "object",
          "properties": {
            "github": { "type": "string" },
            "deploy": { "type": "string" },
            "design": { "type": "string" },
            "workspace": { "type": "string" }
          }
        },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "aiRoadmap": {
          "type": "object",
          "properties": {
            "tasks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" }
                },
                "required": ["title", "description"]
              }
            },
            "technologies": { "type": "array", "items": { "type": "string" } },
            "difficulty": { "type": "string" },
            "timeEstimate": { "type": "string" },
            "copilotTips": { "type": "string" },
            "generatedAt": { "type": "string" }
          }
        }
      },
      "required": ["id", "title", "status", "source", "tags", "tasks", "links", "createdAt", "updatedAt"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "The configuration preferences of the user.",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "aiPersona": { "type": "string" },
        "defaultViewMode": { "type": "string", "enum": ["bento", "kanban", "list"] },
        "theme": { "type": "string", "enum": ["light", "dark"] }
      },
      "required": ["userName", "aiPersona", "defaultViewMode", "theme"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "User development projects."
    },
    "settings/user_config": {
      "schema": "UserSettings",
      "description": "The global user settings/configuration document."
    }
  }
}
